# Dancing 六爻预测系统环境变量配置

# Flask 配置
FLASK_ENV=development
FLASK_DEBUG=True

# 模型配置
MODEL_PATH=./model/gbm_model.pkl
USE_ENSEMBLE=true

# 数据路径
CASES_PATH=./data/cases.json
GUDIAN_CASES_PATH=./data/gudian_cases.json

# API 配置（如需接入外部API）
# OPENAI_API_KEY=your_api_key_here
# DEEPSEEK_API_KEY=your_api_key_here
